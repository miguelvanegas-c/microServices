# Environment variables for docker-compose
# Change these values as appropriate for your environment. Do NOT commit sensitive values to public repos.

# Postgres image and DB credentials
POSTGRES_IMAGE=postgres:15-alpine
POSTGRES_DB=monolito
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5432

# Spring / app
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_PORT=8080
JWT_SECRET=changeitchangeitchangeitchangeit
JWT_EXPIRATION_MS=3600000

# Auth0 (set AUTH0_ENABLED=true and provide values to enable JWT validation)
# Provided Auth0 tenant URL: https://dev-8fakcfsg1icz4j0u.us.auth0.com/api/v2/
# If your Auth0 API has a different Identifier, set AUTH0_AUDIENCE to that identifier.
AUTH0_ENABLED=true
AUTH0_ISSUER_URI=https://dev-8fakcfsg1icz4j0u.us.auth0.com/
AUTH0_AUDIENCE=https://dev-8fakcfsg1icz4j0u.us.auth0.com/api/v2/
AUTH0_JWKS_URI=https://dev-8fakcfsg1icz4j0u.us.auth0.com/.well-known/jwks.json

